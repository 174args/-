# 企业微信配置 - 从管理后台 → 我的企业 → 企业信息 获取
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxxxxxx

# 应用配置 - 从管理后台 → 应用管理 → 你的应用 获取
WECOM_AGENT_ID=1000001
WECOM_AGENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 回调配置 - 在应用 → 接收消息 → 设置API接收 时自己填的
WECOM_TOKEN=yourTokenHere
WECOM_ENCODING_AES_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API Key - https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 服务端口
PORT=3000
